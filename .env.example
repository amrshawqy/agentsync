# Database
DATABASE_URL=postgresql://agentsync:agentsync@localhost:5432/agentsync

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me-in-production
JWT_ISSUER=agentsync
JWT_AUDIENCE=agentsync-api
JWT_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# OAuth
OAUTH_CLIENT_ID=agentsync-default
OAUTH_CLIENT_SECRET=change-me-in-production
PUBLIC_BASE_URL=http://localhost:3000
WEB_BASE_URL=http://localhost:3001

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=debug

# MCP
MCP_SERVER_NAME=agentsync
MCP_SERVER_VERSION=0.1.0

# Self-host bootstrap (set to the email of the first super-admin; falls back to a one-time setup token logged at startup)
# BOOTSTRAP_ADMIN_EMAIL=admin@acme.com
# Comma-separated list of allowed sign-up email domains (empty = open registration)
# SIGNUP_ALLOWED_DOMAINS=acme.com,acme.co

# Email delivery — pluggable provider
EMAIL_PROVIDER=console
EMAIL_FROM=

# Provider: resend
# RESEND_API_KEY=

# Provider: smtp
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASSWORD=

# Provider: ses (AWS)
# SES_REGION=us-east-1
# SES_ACCESS_KEY_ID=
# SES_SECRET_ACCESS_KEY=

# OIDC SSO (optional; configure to enable single sign-on)
# OIDC_ISSUER=https://accounts.google.com
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_SCOPES=openid email profile

# Anthropic (optional; powers describe-what-you-track wizard)
# ANTHROPIC_API_KEY=
