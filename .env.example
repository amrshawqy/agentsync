# Database
DATABASE_URL=postgresql://agentsync:agentsync@localhost:5432/agentsync

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me-in-production
JWT_ISSUER=agentsync
JWT_AUDIENCE=agentsync-api
