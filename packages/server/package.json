{
  "name": "@agentsync/server",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@agentsync/db": "workspace:*",
    "@agentsync/types": "workspace:*",
    "@anthropic-ai/sdk": "^0.96.0",
    "@aws-sdk/client-s3": "^3.1048.0",
    "@aws-sdk/client-ses": "^3.1048.0",
    "@aws-sdk/s3-request-presigner": "^3.1048.0",
    "@hono/node-server": "^2.0.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "archiver": "^8.0.0",
    "csv-parse": "^6.2.1",
    "drizzle-orm": "^0.45.2",
    "handlebars": "^4.7.9",
    "hono": "^4.12.19",
    "ioredis": "^5.10.1",
    "jose": "^6.2.3",
    "nodemailer": "^8.0.7",
    "openid-client": "^6.8.4",
    "postgres": "^3.4.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.3",
    "@types/node": "^25.3.2",
    "@types/nodemailer": "^8.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
