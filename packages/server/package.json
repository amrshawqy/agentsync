{
  "name": "@agentsync/server",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@agentsync/db": "workspace:*",
    "@agentsync/types": "workspace:*",
    "@anthropic-ai/sdk": "^0.92.0",
    "@aws-sdk/client-s3": "^3.1000.0",
    "@aws-sdk/client-ses": "^3.1041.0",
    "@aws-sdk/s3-request-presigner": "^3.1000.0",
    "@hono/node-server": "^1.19.13",
    "@modelcontextprotocol/sdk": "^1.7.0",
    "archiver": "^7.0.1",
    "csv-parse": "^5.6.0",
    "drizzle-orm": "^0.45.2",
    "handlebars": "^4.7.8",
    "hono": "^4.12.18",
    "ioredis": "^5.4.2",
    "jose": "^5.9.6",
    "nodemailer": "^8.0.7",
    "openid-client": "^6.8.4",
    "postgres": "^3.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.3",
    "@types/node": "^25.8.0",
    "@types/nodemailer": "^8.0.0",
    "tsx": "^4.22.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
