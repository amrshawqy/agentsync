{
  "name": "@agentsync/db",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch",
    "generate": "tsc && drizzle-kit generate --config=drizzle.config.build.ts",
    "migrate": "tsx src/migrate.ts",
    "db:generate": "tsc && drizzle-kit generate --config=drizzle.config.build.ts",
    "db:migrate": "tsx src/migrate.ts",
    "seed": "tsx src/seed/index.ts"
  },
  "dependencies": {
    "@agentsync/types": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
