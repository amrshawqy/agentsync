		],
		"budgets": [
			{ "name": "Q1 2026 Engineering", "account_id": "@ref:accounts:1", "amount": 50000, "spent": 12000, "period_start": "2026-01-01", "period_end": "2026-03-31", "status": "active" },
			{ "name": "Q1 2026 Software", "account_id": "@ref:accounts:2", "amount": 15000, "spent": 8500, "period_start": "2026-01-01", "period_end": "2026-03-31", "status": "active" }
		]
	},
	"instructions": {
		"rules": "Invoices overdue by more than 30 days must be escalated. Expenses over $5,000 require director approval. Payments must be linked to their corresponding invoice. Budget utilization above 90% should trigger an alert.",
		"guidance": "When recording a payment, update the corresponding invoice status to 'paid'. Track budget spending in real time — compare expenses against budgets for the current period."
	}
}
