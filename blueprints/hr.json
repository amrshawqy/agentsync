	"instructions": {
		"rules": "Leave requests longer than 10 days require HR director approval. Performance reviews must be completed within 2 weeks of the review period ending. Offboarded employees cannot submit leave requests.",
		"guidance": "When looking up an employee, also check their department and manager for full context. Flag reviews that are past due."
	}
}
